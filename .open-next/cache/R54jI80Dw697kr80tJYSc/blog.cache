:\\\"Unsplash\\\",\\\"source\\\":\\\"pollinations_ai_local\\\",\\\"prompt\\\":\\\"ancient gnarled thousand-year-old olive tree dramatic golden sunset, stone ruins Mediterranean civilization, epic landscape history, cinematic atmosphere heritage\\\",\\\"generated_at\\\":\\\"2026-04-29\\\",\\\"quality_score\\\":8.5},\\\"oleocanthal-anti-inflammation-brain-protection\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/0b12fe98ad674377bb5c6294cd09f2fc_d1c42.png\\\",\\\"alt\\\":\\\"油橄欖醛的抗炎密碼\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"human brain silhouette glowing olive green light, anti-inflammation shield, neuroscience visualization, mediterranean olive branch overlay, dramatic dark background, artistic medical photography\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":9.5},\\\"hydroxytyrosol-brain-cognition-memory\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/652adb38b9734a52bb8924925390f29d_3ef5f.png\\\",\\\"alt\\\":\\\"羥基酪醇與大腦記憶\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"neurons firing golden light, olive oil molecular structure overlay, brain cognition enhancement, glowing synapses, olive green gold tones, scientific macro photography, harvard lab aesthetic\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":9},\\\"olive-oil-terroir-spain-greece-italy\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/21efe059834d48fdb33d24f0285fb2de_fe61b.png\\\",\\\"alt\\\":\\\"橄欖油的風土密碼\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"three mediterranean landscapes montage, olive grove terroir, Spain Greece Italy landmarks, golden sunset over ancient olive trees, travel food photography, cinematic wide shot\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":10},\\\"squalene-olive-oil-skin-beauty-molecular\\\":{\\\"url\\\":\\\"/images/covers/squalene-olive-oil-skin-beauty-molecular.jpg\\\",\\\"alt\\\":\\\"橄欖油護膚的分子美學\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"pollinations_ai_local\\\",\\\"prompt\\\":\\\"luminous glowing skin close-up golden olive oil droplet on cheek, squalene skin barrier molecular beauty concept, luxury beauty editorial soft diffused light\\\",\\\"generated_at\\\":\\\"2026-04-29\\\",\\\"quality_score\\\":8.5},\\\"oleocanthal-pungency-anti-inflammation\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/5be6f88930b24b40bb22796d30142dd3_86b5d.png\\\",\\\"alt\\\":\\\"橄欖油辣喉感背後的分子秘密\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"close-up fresh green olive being cold-pressed, golden-green oil droplet falling, macro photography, dark moody background, pungent sensation concept, cinematic dramatic lighting\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":8},\\\"morning-ritual-evoo-metabolism\\\":{\\\"url\\\":\\\"/images/covers/morning-ritual-evoo-metabolism.jpg\\\",\\\"alt\\\":\\\"每日晨飲橄欖油：為什麼這個三分鐘儀式能重啟您一整天的代謝引擎？\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"pollinations_ai_local\\\",\\\"generated_at\\\":\\\"2026-04-29\\\",\\\"quality_score\\\":8.5,\\\"prompt\\\":\\\"elegant morning ritual golden EVOO spoonful ceramic spoon, soft sunlight streaming through window, minimalist Japanese-inspired lifestyle, wooden table fresh herbs bokeh\\\"},\\\"evoo-sensory-evaluation-ioc-standards\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/1bf7c22a57b7469d8d47e9ec5ade4473_dfdf0.png\\\",\\\"alt\\\":\\\"橄欖油感官評鑑 IOC 標準\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"professional olive oil tasting, expert smelling cobalt blue glass, sensory evaluation, white tablecloth, warm studio lighting, sommelier aesthetic, food photography\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":9},\\\"olive-oil-fraud-detection-authentic-vs-fake\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/5f267745bd334f2c8c472bbaba2b61f2_db346.png\\\",\\\"alt\\\":\\\"橄欖油真假辨別\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"two olive oil bottles comparison authentic vs fake, magnifying glass revealing truth, laboratory forensic concept, dramatic split lighting, yellow warning tones, investigative photography\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":9.5},\\\"olive-oil-polyphenol-content-how-to-verify\\\":{\\\"url\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/acd68586463e4e9e8717cee51f43ba5e_2c82d.png\\\",\\\"alt\\\":\\\"橄欖油多酚含量驗證\\\",\\\"credit\\\":\\\"Unsplash\\\",\\\"source\\\":\\\"skywork_ai\\\",\\\"prompt\\\":\\\"laboratory testing olive oil samples, polyphenol analysis equipment, scientific glass tubes golden liquid, precision measurement, clean clinical food science photography\\\",\\\"generated_at\\\":\\\"2026-04-17\\\",\\\"quality_score\\\":9},\\\"2026-evoo-quality-polyphenol-index\\\":{\\\"url\\\":\\\"https://image.pollinations.ai/prompt/olive%20oil%20polyphenol%20molecular%20structure%20visualization%2C%20laboratory%20glass%20vials%20with%20golden%20liquid%2C%20scientific%20data%20charts%20on%20dark%20background%2C%20precision%20measurement%20aesthetic%2C%20extra%20virgin%20olive%20oil%20quality%20testing%2C%20high-tech%20science%20photography?width=1200\\u0026height=630\\u0026model=flux\\u0026seed=1001\\u0026nologo=true\\\",\\\"alt\\\":\\\"2026 高多酚橄欖油品質指數\\\",\\\"source\\\":\\\"pollinations_ai\\\",\\\"prompt\\\":\\\"olive oil polyphenol molecular structure visualization, laboratory glass vials with golden liquid, scientific data charts, dark elegant background, precision measurement aesthetic, extra virgin olive oil quality testing\\\",\\\"generated_at\\\":\\\"2026-04-29\\\",\\\"quality_score\\\":7.5},\\\"hydroxytyrosol-brain-cognition-2026\\\":{\\\"url\\\"