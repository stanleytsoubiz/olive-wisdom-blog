true}]}],[\"$\",\"div\",null,{\"className\":\"p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\",\"children\":\"IOC 感官評鑑全解析：為什麼一瓶橄欖油的靈魂，藏在鼻尖的三秒鐘？\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mt-2\",\"children\":[10,\" 分鐘閱讀\"]}]]}]]}]}],[\"$\",\"$L2\",\"olive-oil-polyphenol-content-how-to-verify\",{\"href\":\"/blog/olive-oil-polyphenol-content-how-to-verify\",\"className\":\"group\",\"children\":[\"$\",\"article\",null,{\"className\":\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative h-36 overflow-hidden\",\"children\":[\"$\",\"$L1b\",null,{\"src\":\"https://picture-search.skywork.ai/skills/upload/2026-04-17/acd68586463e4e9e8717cee51f43ba5e_2c82d.png\",\"alt\":\"多酚含量的真相：為什麼標籤上的數字，可能是您最重要的健康決策依據？ — 知橄生活 Olive Wisdom\",\"fill\":true,\"className\":\"object-cover group-hover:scale-105 transition-transform duration-300\",\"unoptimized\":true}]}],[\"$\",\"div\",null,{\"className\":\"p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\",\"children\":\"多酚含量的真相：為什麼標籤上的數字，可能是您最重要的健康決策依據？\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mt-2\",\"children\":[8,\" 分鐘閱讀\"]}]]}]]}]}],[\"$\",\"$L2\",\"olive-oil-fraud-detection-authentic-vs-fake\",{\"href\":\"/blog/olive-oil-fraud-detection-authentic-vs-fake\",\"className\":\"group\",\"children\":[\"$\",\"article\",null,{\"className\":\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative h-36 overflow-hidden\",\"children\":[\"$\",\"$L1b\",null,{\"src\":\"https://picture-search.skywork.ai/skills/upload/2026-04-17/5f267745bd334f2c8c472bbaba2b61f2_db346.png\",\"alt\":\"橄欖油真偽鑑別：為什麼歐盟每年查獲數十噸摻假油，而您的舌頭可能是最後一道防線？ — 知橄生活 Olive Wisdom\",\"fill\":true,\"className\":\"object-cover group-hover:scale-105 transition-transform duration-300\",\"unoptimized\":true}]}],[\"$\",\"div\",null,{\"className\":\"p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\",\"children\":\"橄欖油真偽鑑別：為什麼歐盟每年查獲數十噸摻假油，而您的舌頭可能是最後一道防線？\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mt-2\",\"children\":[9,\" 分鐘閱讀\"]}]]}]]}]}]]}]]}]}]\n22:[\"$\",\"div\",null,{\"className\":\"mt-12 pt-8 border-t border-olive-100\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"children\":\"💬\"}],\" 常見問題\"]}],[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"details\",\"0\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"西班牙、希臘和義大利橄欖油有什麼根本差異？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"三國橄欖油的差異來自品種、氣候和飲食文化三個層面。西班牙：以皮誇爾（Picual）和阿貝基納（Arbequina）為主力品種，穩定性高，辣感明顯，適合烹飪；希臘：以科雷克尼（Koroneiki）為核心，多酚含量通常最高，苦辣感強烈，每人年均消費量全球最高（約 24kg）；義大利：品種最多元（200+），從溫和圓潤的 Leccino 到強烈辛辣的 Coratina，區域風格差異極大，藝術性高。\"}]]}],[\"$\",\"details\",\"1\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"PDO 標示如何保障橄欖油的風土真實性？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"歐盟 PDO（Protected Designation of Origin，原產地名稱保護）認證要求橄欖的生長、採收和榨油必須全部在指定地理區域內完成，且需符合該區域的傳統品種和生產方式。例如「Kalamata PDO」確保油來自希臘卡拉馬塔地區的馬維利亞（Koroneiki/Mavrolies）品種；「Toscano IGP」確保義大利托斯卡尼傳統品種和冷榨工藝。購買 PDO 標示是保障風土真實性的最可靠公開認證。\"}]]}],[\"$\",\"details\",\"2\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"為什麼希臘橄欖油的品質往往被低估？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"希臘長期是「隱形冠軍」：人均橄欖油消費全球最高，Koroneiki 品種的多酚含量居全球前列，但品牌建設和國際行銷長期落後於義大利和西班牙。歷史上，大量希臘散裝橄欖油被義大利廠商進口、調配後以義大利品牌出口，賺取高額品牌溢價。近年希臘小農品牌崛起（如 Gaea、Iliada），開始在國際競賽中展現實力，NYIOOC 金牌數量年年提升。\"}]]}]]}]]}]\n23:[\"$\",\"div\",null,{\"className\":\"mt-12 pt-8 border-t border-olive-100\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"children\":\"📚\"}],\" 參考文獻\"]}],[\"$\",\"ol\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",1,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"International Olive Council (IOC). World Olive Oil Figures 2024-2025.\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",2,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"Servili, M. et al. (2016). Phenolic compounds in olive oil: Importance from a health perspective. Molecules.\"}]]}],[\"$\",\"li\",\"2\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",3,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"Aparicio, R. & Harwood, J. (2013). Handbook of Olive Oil: Analysis and Properties. Springer.\"}]]}],[\"$\",\"li\",\"3\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",4,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"Cicerale, S. et al. (2012). Chemistry and health of olive oil phenolics. Critical Reviews in Food Science.\"}]]}],[\"$\",\"li\",\"4\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",5,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"European Commission. Protected Designations of Origin (PDO) database 2024.\"}]]}]]}]]}]\n24:[\"$\",\"div\",null,{\"className\":\"mt-10 pt-8 border-t border-gray-100 flex gap-4\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/blog\",\"className\":\"inline-flex items-center gap-2 text-sm text-olive-600 hover:text-olive-800 font-medium hover:underline\",\"children\":\"← 返回文章列表\"}],[\"$\",\"$L2\",null,{\"href\":\"/#subscribe\",\"className\":\"ml-auto inline-flex items-center gap-2 bg-olive-700 hover:bg-olive-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors\",\"children\":\"訂閱知橄週報 🫒\"}]]}]\n17:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n13:null\n15:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"橄欖油的風土密碼：為什麼西班牙、希臘與義大利的同種橄欖，能孕育出截然不同的靈魂？｜知橄生活｜知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"法國人用「風土（Terroir）」解釋為何同一品種的葡萄，在不同土地上能釀出截然不同的靈魂。橄欖油的世界，同樣適用這個哲學。一位知性品飲者，必須理解產地才能真正讀懂一瓶油。\"}],[\"$\",\"link\",\"2\",{\"rel\":\"author\",\"href\":\"https://olive-wisdom.com\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"知橄生活研究團隊\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"橄欖油,特級初榨橄欖油,EVOO,地中海飲食,抗衰老,多酚,羥基酪醇,SIRT1,健康飲食\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"6\",{\"name\":\"publisher\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"7\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"link\",\"8\",{\"rel\":\"canonical\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-terroir-spain-greece-italy/\"}],[\"$\",\"link\",\"9\",{\"rel\":\"alternate\",\"hrefLang\":\"zh-TW\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-terroir-spain-greece-italy/\"}],[\"$\",\"link\",\"10\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-terroir-spain-greece-italy/\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:title\",\"content\":\"橄欖油的風土密碼：為什麼西班牙、希臘與義大利的同種橄欖，能孕育出截然不同的靈魂？\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:description\",\"content\":\"法國人用「風土（Terroir）」解釋為何同一品種的葡萄，在不同土地上能釀出截然不同的靈魂。橄欖油的世界，同樣適用這個哲學。一位知性品飲者，必須理解產地才能真正讀懂一瓶油。\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:url\",\"content\":\"https://olive-wisdom.com/blog/olive-oil-terroir-spain-greece-italy/\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:site_name\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:locale\",\"content\":\"zh_TW\"}],[\"$\",\"meta\",\"16\",{\"property\":\"og:image\",\"content\":\"https://picture-search.s