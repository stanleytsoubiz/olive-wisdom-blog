\"$L2\",null,{\"href\":\"/terms\",\"className\":\"hover:text-white transition-colors\",\"children\":\"使用條款\"}],[\"$\",\"$L2\",null,{\"href\":\"/about\",\"className\":\"hover:text-white transition-colors\",\"children\":\"關於我們\"}]]}]]}]}]]}]\n9:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$Lf\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L10\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$Lf\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L10\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[\"$L11\",null,[\"$\",\"$L12\",null,{\"children\":[\"$L13\",[\"$\",\"$L14\",null,{\"promise\":\"$@15\"}]]}]]}]\nc:[\"$\",\"$1\",\"h\",{\"children\":[null,[[\"$\",\"$L16\",null,{\"children\":\"$L17\"}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]],[\"$\",\"$L18\",null,{\"children\":[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$19\",null,{\"fallback\":null,\"children\":\"$L1a\"}]}]}]]}]\n1b:I[1356,[\"619\",\"static/chunks/619-ba102abea3e3d0e4.js\",\"356\",\"static/chunks/356-1cbf59d25a49fb83.js\",\"953\",\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\"],\"Image\"]\n11:[\"$\",\"main\",null,{\"className\":\"min-h-screen bg-white\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Article\\\",\\\"headline\\\":\\\"2026 橄欖油品質指數：為什麼高多酚 (High Polyphenol) 才是真正的權威標籤？\\\",\\\"description\\\":\\\"不談口感，我們談數據。解析 2026 年新產季歐盟與 IOC 標準下的高多酚橄欖油趨勢，教您讀懂鑑定報告中的羥基酪醇 (Hydroxytyrosol) 數值。\\\",\\\"image\\\":\\\"https://bnotescoffee.com/images/ai/evoo-polyphenol-science.jpg\\\",\\\"datePublished\\\":\\\"2026-04-27\\\",\\\"dateModified\\\":\\\"2026-04-27\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"知橄生活研究團隊\\\",\\\"url\\\":\\\"https://olive-wisdom.com\\\"},\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"知橄生活 Olive Wisdom\\\",\\\"url\\\":\\\"https://olive-wisdom.com\\\"},\\\"url\\\":\\\"https://olive-wisdom.com/blog/2026-evoo-quality-polyphenol-index\\\",\\\"mainEntityOfPage\\\":{\\\"@type\\\":\\\"WebPage\\\",\\\"@id\\\":\\\"https://olive-wisdom.com/blog/2026-evoo-quality-polyphenol-index\\\"},\\\"inLanguage\\\":\\\"zh-TW\\\",\\\"wordCount\\\":300}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"首頁\\\",\\\"item\\\":\\\"https://olive-wisdom.com\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"知識庫\\\",\\\"item\\\":\\\"https://olive-wisdom.com/blog\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"2026 橄欖油品質指數：為什麼高多酚 (High Polyphenol) 才是真正的權威標籤？\\\",\\\"item\\\":\\\"https://olive-wisdom.com/blog/2026-evoo-quality-polyphenol-index\\\"}]}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"2026 年橄欖油市場的品質標準有什麼新趨勢？\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"2026 年橄欖油市場出現三個重要品質趨勢：(1) 多酚量化標示普及——越來越多品牌開始在標籤上主動標示總酚含量（TPC）或羥基酪醇含量；(2) QR Code 產品溯源——掃碼即可查看特定批次的採收日期、莊園位置和第三方 CoA 報告；(3) 早摘油（Early Harvest）市場擴大——消費者對高多酚意識提升，帶動早摘橄欖油的溢價市場成長。IOC 也在 2024 年更新了感官評鑑規範，強化了對缺陷偵測的標準化要求。\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"如何用多酚指數評估橄欖油的健康價值？\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"多酚指數（Polyphenol Index）是一個綜合評估框架：總酚含量（TPC）≥500mg/kg 為頂級（Premium）；250-500mg/kg 為高品質（High Quality）；100-250mg/kg 為標準品質（Standard）；<100mg/kg 多酚功效極低，不值得為健康因素溢價購買。然而，真正重要的不只是總量，而是各類多酚的比例——Oleocanthal 和 Hydroxytyrosol 的含量比整體 TPC 更能預測特定健康功效。\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"2026 年台灣市場能買到真正的高多酚橄欖油嗎？\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"可以，但需要懂得辨識。台灣進口管道中，部分專業有機食品通路（如 Jason's、棉花田等）有進口具備 CoA 報告的高品質 EVOO。挑選要點：確認採收年份為 2025 或 2026 年（避開老油）；詢問進口商是否有多酚含量（TPC）的第三方檢驗報告；品牌認證優先選擇 NYIOOC 或 EVOOLEUM 得獎產品；預算在每瓶 NT$600-1,500 以上的進口 EVOO 較可能達到高多酚標準。\\\"}}]}\"}}],[\"$\",\"div\",null,{\"className\":\"relative h-[40vw] min-h-[200px] max-h-[260px] md:h-[480px] w-full\",\"children\":[[\"$\",\"$L1b\",null,{\"src\":\"https://image.pollinations.ai/prompt/olive%20oil%20polyphenol%20molecular%20structure%20visualization%2C%20laboratory%20glass%20vials%20with%20golden%20liquid%2C%20scientific%20data%20charts%20on%20dark%20background%2C%20precision%20measurement%20aesthetic%2C%20extra%20virgin%20olive%20oil%20quality%20testing%2C%20high-tech%20science%20photography?width=1200&height=630&model=flux&seed=1001&nologo=true\",\"alt\":\"專業實驗室背景下的橄欖油樣品，展示多酚檢測數據\",\"fill\":true,\"className\":\"object-cover\",\"priority\":true,\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent\"}],[\"$\",\"div\",null,{\"className\":\"absolute bottom-0 left-0 right-0 px-6 py-8 max-w-4xl mx-auto\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xs font-semibold px-3 py-1.5 rounded-full mb-4 inline-block bg-emerald-100 text-emerald-800\",\"children\":\"科學萃取\"}],\"$L1c\"]}]]}],\"$L1d\",\"$L1e\",\"$L1f\",\"$L20\"]}]\n21:I[286,[\"619\",\"static/chunks/619-ba102abea3e3d0e4.js\",\"356\",\"static/chunks/356-1cbf59d25a49fb83.js\",\"953\",\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\"],\"default\"]\n27:I[7025,[\"619\",\"static/chunks/619-ba102abea3e3d0e4.js\",\"356\",\"static/chunks/356-1cbf59d25a49fb83.js\",\"953\",\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\"],\"default\"]\n1c:[\"$\",\"h1\",null,{\"className\":\"text-2xl md:text-4xl font-bold text-white leading-tight mt-2 max-w-3xl\",\"children\":\"2026 橄欖油品質指數：為什麼高多酚 (High Polyphenol) 才是真正的權威標籤？\"}]\n22:T3577,<h1 class=\"text-3xl font-bold text-olive-900 mt-8 mb-4\">2026 橄欖油品質指數：為什麼高多酚才是真正的權威標籤？</h1>\n        <ViewTracker slug={slug} />\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">如果您買橄欖油是為了健康，那麼 2026 年您最該關注的數字不是價格，而是 <strong class=\"font-semibold text-olive-900\">「多酚含量 (Polyphenol Content)」</strong>。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在過去的十年中，我們習慣用「初榨」來定義好油。但隨著消費者科學素養的提升與第三方檢測技術的民主化，知橄生活研究團隊認為：<strong class=\"font-semibold text-olive-900\">沒有數據支撐的「特級初榨」，在 2026 年不具備任何健康意義。</strong></p>\n<h2 id=\"h-為什麼特級初榨標籤已不夠用-3\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">為什麼「特級初榨」標籤已不夠用？</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">根據 IOC（國際橄欖理事會）的定義，「特級初榨」只需滿足：</p>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>游離酸度（Free Acidity）< 0.8%</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>過氧化值（Peroxide Value）< 20 meq/kg</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>感官評鑑無缺陷</span></li>\n</ul>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">注意：IOC 的 EVOO 定義完全不包含多酚含量的下限要求。</strong></p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">這意味著一瓶多酚含量僅 50mg/kg 的橄欖油，只要酸度和過氧化值達標，就可以合法標示「特級初榨橄欖油（Extra Virgin Olive Oil）」。而市場上大量的超市 EVOO，其多酚含量確實落在這個範圍。</p>\n<h2 id=\"h-羥基酪醇橄欖油中的黃金分子-12\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">羥基酪醇：橄欖油中的「黃金分子」</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">為什麼有些油喝起來有強烈的辛辣感和苦味？那不是油壞了，那是<strong class=\"font-semibold text-olive-900\">多酚在與您的感官對話</strong>。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">羥基酪醇 (Hydroxytyrosol)</strong> 是橄欖油中最重要的酚類化合物，也是唯一獲得 EFSA（歐盟食品安全局）正式認可、具備健康聲明資格的橄欖油成分：</p>\n<blockquote class=\"border-l-4 border-olive-400 bg-olive-50 pl-5 pr-4 py-3 rounded-r-xl my-6 italic text-gray-600\">\n<p class=\"mb-1\"><em class=\"italic\">「橄欖油多酚有助於保護血液脂質免受氧化應激。」</em>  </p>\n<p class=\"mb-1\">——EU Regulation No 432/2012（條件：每日攝取含至少 5mg 羥基酪醇及其衍生物的橄欖油）</p>\n</blockquote>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在 2025-2026 年的新產季中，頂尖的 <strong class=\"font-semibold text-olive-900\">Coratina</strong> 品種（義大利南部 Puglia 產區）多酚含量甚至突破了 <strong class=\"font-semibold text-olive-900\">800mg/kg</strong>，而高品質的 <strong class=\"font-semibold text-olive-900\">Koroneiki</strong>（希臘）和 <strong class=\"font-semibold text-olive-900\">Picual</strong>（西班牙）早摘油通常落在 400-700mg/kg 範圍。</p>\n<h2 id=\"h-2026多酚品質分級完整框架-20\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">2026 多酚品質分級完整框架</h2>\n<div class=\"overflow-x-auto my-8\"><table class=\"w-full border-collapse text-sm\"><tr class=\"hover:bg-olive-50\"><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">等級</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">多酚含量</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">定義</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">最佳用途</th></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">醫療級 (Therapeutic)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">>500 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">具強大抗炎潛力，建議空腹生飲</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">健康補充、直接飲用</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">高品質級 (Premium)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">250-500 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">符合 EFSA 健康聲明標準</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">沙拉淋油、低溫料理</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">標準級 (Standard)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">100-250 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">符合 IOC EVOO 基本標準</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">日常烹飪</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">基礎級 (Basic)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \"><100 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">健康活性極低</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">不建議支付溢價</td></tr></table></div>\n<h2 id=\"h-讀懂coa品質鑑定報告真正的決策依據-22\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">讀懂 CoA（品質鑑定報告）：真正的決策依據</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">真正的懂油者不看包裝設計，看 <strong class=\"font-semibold text-olive-900\">Certificate of Analysis（CoA）</strong>。以下是一份完整 CoA 中您需要關注的關鍵數據：</p>\n<h3 id=\"h-化學指標必看-24\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">化學指標（必看）</h3>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">總酚含量（Total Phenols / TPC）：</strong> 以 mg/kg 表示，目標 >300mg/kg</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">羥基酪醇（Hydroxytyrosol）含量：</strong> 目標 >5mg（每日攝取量換算）</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">油橄欖醛（Oleocanthal）含量：</strong> 辛辣感的來源，越高越好</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">游離酸度（Free Acidity）：</strong> <0.3% 為優質，<0.8% 為 EVOO 法定標準</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">過氧化值（Peroxide Value）：</strong> <10 meq/kg 為新鮮，>20 meq/kg 不符合 EVOO 標準</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">K232 / K270 值：</strong> UV 吸光度，檢測精煉油摻混的指標</span></li>\n</ul>\n<h3 id=\"h-時效性驗證同樣關鍵-33\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">時效性驗證（同樣關鍵）</h3>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">CoA 出具日期：</strong> 必須是採收當季出具，超過 12 個月的報告對當前品質無任何保證</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">批號（Lot Number）：</strong> 確認您購買的批次與 CoA 批號一致</span></li>\n</ul>\n<blockquote class=\"border-l-4 border-olive-400 bg-olive-50 pl-5 pr-4 py-3 rounded-r-xl my-6 italic text-gray-600\">\n<p class=\"mb-1\"><strong class=\"font-semibold text-olive-900\">知橄生活實驗室筆記：</strong></p>\n<p class=\"mb-1\">如果一家品牌宣稱其多酚極高，但 CoA 日期是 2024 年，請直接忽略。多酚會隨著儲存時間以每年約 30-40% 的速度衰減。一瓶 2024 年出具 CoA 顯示多酚 600mg/kg 的油，到 2026 年底可能只剩 200mg/kg 以下。</p>\n</blockquote>\n<h2 id=\"h-2026年的三大市場趨勢-42\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">2026 年的三大市場趨勢</h2>\n<h3 id=\"h-趨勢一qrcode溯源全面普及-43\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢一：QR Code 溯源全面普及</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">頂尖品牌（特別是希臘和義大利精品莊園）已開始在瓶身印製 QR Code，掃碼即可查看：</p>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>採收莊園的 GPS 座標</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>採收日期與壓榨時間（採收至壓榨的間隔越短越好，目標 <4 小時）</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>當批次第三方 CoA 完整報告</span></li>\n</ul>\n<h3 id=\"h-趨勢二早摘油earlyharvest市場-50\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢二：早摘油（Early Harvest）市場爆發</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在 10 月初橄欖尚未完全成熟時採收的「早摘油」（也稱「青採油」或 Agura），多酚含量是完熟橄欖的 2-3 倍，但果實出油率較低（約 8-12% vs 完熟的 18-20%），導致成本更高。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">知橄生活預測：2026 年早摘油在台灣消費者的認知度將從 15% 提升至 35%，帶動優質早摘油的進口量增加。</p>\n<h3 id=\"h-趨勢三多酚認證標章的崛起-53\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢三：「多酚認證」標章的崛起</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">EVOOLEUM、NYIOOC（紐約國際橄欖油大賽）等國際評鑑機構開始在官方標章旁附加多酚含量數值，讓消費者一眼識別。這是繼「有機認證」之後，橄欖油行業最重要的品質識別革命。</p>\n<h2 id=\"h-台灣消費者2026年實戰選購指南-55\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">台灣消費者 2026 年實戰選購指南</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">在台灣，如何找到真正的高多酚橄欖油？</strong></p>\n<ol class=\"list-decimal pl-6 space-y-2 my-4\">\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">詢問 CoA：</strong> 向實體通路（有機商店、葡萄酒專賣店、進口食品行）直接索取，信譽好的進口商應能提供。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">辨識品種優先序：</strong> Coratina > Koroneiki 早摘 > Picual 早摘 > 其他品種。品種是多酚含量的遺傳基礎。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">看採收年份：</strong> 2025 年 10 月–2026 年 1 月採收的南半球或北半球新油，是 2026 年市場上最新鮮的選擇。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">預算參考：</strong> 真正高多酚（>400mg/kg）的進口 EVOO，在台灣市場的合理零售價落在 <strong class=\"font-semibold text-olive-900\">NT$700-1,800/500ml</strong>，低於此價格的高多酚宣稱值得存疑。</li>\n</ol>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">本月，知橄生活研究團隊將對台灣市場熱銷的 10 款宣稱「高多酚」橄欖油進行盲測與第三方送驗，結果將完整公布。</p>\n<hr class=\"border-olive-200 my-10\" />\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><em class=\"italic\">利益揭露：知橄生活堅持獨立評測。本文提及之檢測數據由協力實驗室提供，部分連結包含聯盟營銷參數。</em></p>1d:[\"$\",\"$L21\",null,{\"htmlContent\":\"$22\"}]\n23:T3577,<h1 class=\"text-3xl font-bold text-olive-900 mt-8 mb-4\">2026 橄欖油品質指數：為什麼高多酚才是真正的權威標籤？</h1>\n        <ViewTracker slug={slug} />\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">如果您買橄欖油是為了健康，那麼 2026 年您最該關注的數字不是價格，而是 <strong class=\"font-semibold text-olive-900\">「多酚含量 (Polyphenol Content)」</strong>。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在過去的十年中，我們習慣用「初榨」來定義好油。但隨著消費者科學素養的提升與第三方檢測技術的民主化，知橄生活研究團隊認為：<strong class=\"font-semibold text-olive-900\">沒有數據支撐的「特級初榨」，在 2026 年不具備任何健康意義。</strong></p>\n<h2 id=\"h-為什麼特級初榨標籤已不夠用-3\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">為什麼「特級初榨」標籤已不夠用？</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">根據 IOC（國際橄欖理事會）的定義，「特級初榨」只需滿足：</p>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>游離酸度（Free Acidity）< 0.8%</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>過氧化值（Peroxide Value）< 20 meq/kg</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>感官評鑑無缺陷</span></li>\n</ul>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">注意：IOC 的 EVOO 定義完全不包含多酚含量的下限要求。</strong></p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">這意味著一瓶多酚含量僅 50mg/kg 的橄欖油，只要酸度和過氧化值達標，就可以合法標示「特級初榨橄欖油（Extra Virgin Olive Oil）」。而市場上大量的超市 EVOO，其多酚含量確實落在這個範圍。</p>\n<h2 id=\"h-羥基酪醇橄欖油中的黃金分子-12\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">羥基酪醇：橄欖油中的「黃金分子」</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">為什麼有些油喝起來有強烈的辛辣感和苦味？那不是油壞了，那是<strong class=\"font-semibold text-olive-900\">多酚在與您的感官對話</strong>。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">羥基酪醇 (Hydroxytyrosol)</strong> 是橄欖油中最重要的酚類化合物，也是唯一獲得 EFSA（歐盟食品安全局）正式認可、具備健康聲明資格的橄欖油成分：</p>\n<blockquote class=\"border-l-4 border-olive-400 bg-olive-50 pl-5 pr-4 py-3 rounded-r-xl my-6 italic text-gray-600\">\n<p class=\"mb-1\"><em class=\"italic\">「橄欖油多酚有助於保護血液脂質免受氧化應激。」</em>  </p>\n<p class=\"mb-1\">——EU Regulation No 432/2012（條件：每日攝取含至少 5mg 羥基酪醇及其衍生物的橄欖油）</p>\n</blockquote>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在 2025-2026 年的新產季中，頂尖的 <strong class=\"font-semibold text-olive-900\">Coratina</strong> 品種（義大利南部 Puglia 產區）多酚含量甚至突破了 <strong class=\"font-semibold text-olive-900\">800mg/kg</strong>，而高品質的 <strong class=\"font-semibold text-olive-900\">Koroneiki</strong>（希臘）和 <strong class=\"font-semibold text-olive-900\">Picual</strong>（西班牙）早摘油通常落在 400-700mg/kg 範圍。</p>\n<h2 id=\"h-2026多酚品質分級完整框架-20\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">2026 多酚品質分級完整框架</h2>\n<div class=\"overflow-x-auto my-8\"><table class=\"w-full border-collapse text-sm\"><tr class=\"hover:bg-olive-50\"><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">等級</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">多酚含量</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">定義</th><th class=\"border border-olive-300 px-4 py-2 font-semibold text-sm\" class=\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\">最佳用途</th></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">醫療級 (Therapeutic)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">>500 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">具強大抗炎潛力，建議空腹生飲</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">健康補充、直接飲用</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">高品質級 (Premium)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">250-500 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">符合 EFSA 健康聲明標準</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">沙拉淋油、低溫料理</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">標準級 (Standard)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">100-250 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">符合 IOC EVOO 基本標準</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">日常烹飪</td></tr><tr class=\"hover:bg-olive-50\"><td class=\"border border-olive-200 px-4 py-2 text-sm \">基礎級 (Basic)</td><td class=\"border border-olive-200 px-4 py-2 text-sm \"><100 mg/kg</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">健康活性極低</td><td class=\"border border-olive-200 px-4 py-2 text-sm \">不建議支付溢價</td></tr></table></div>\n<h2 id=\"h-讀懂coa品質鑑定報告真正的決策依據-22\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">讀懂 CoA（品質鑑定報告）：真正的決策依據</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">真正的懂油者不看包裝設計，看 <strong class=\"font-semibold text-olive-900\">Certificate of Analysis（CoA）</strong>。以下是一份完整 CoA 中您需要關注的關鍵數據：</p>\n<h3 id=\"h-化學指標必看-24\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">化學指標（必看）</h3>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">總酚含量（Total Phenols / TPC）：</strong> 以 mg/kg 表示，目標 >300mg/kg</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">羥基酪醇（Hydroxytyrosol）含量：</strong> 目標 >5mg（每日攝取量換算）</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">油橄欖醛（Oleocanthal）含量：</strong> 辛辣感的來源，越高越好</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">游離酸度（Free Acidity）：</strong> <0.3% 為優質，<0.8% 為 EVOO 法定標準</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">過氧化值（Peroxide Value）：</strong> <10 meq/kg 為新鮮，>20 meq/kg 不符合 EVOO 標準</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">K232 / K270 值：</strong> UV 吸光度，檢測精煉油摻混的指標</span></li>\n</ul>\n<h3 id=\"h-時效性驗證同樣關鍵-33\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">時效性驗證（同樣關鍵）</h3>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">CoA 出具日期：</strong> 必須是採收當季出具，超過 12 個月的報告對當前品質無任何保證</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span><strong class=\"font-semibold text-olive-900\">批號（Lot Number）：</strong> 確認您購買的批次與 CoA 批號一致</span></li>\n</ul>\n<blockquote class=\"border-l-4 border-olive-400 bg-olive-50 pl-5 pr-4 py-3 rounded-r-xl my-6 italic text-gray-600\">\n<p class=\"mb-1\"><strong class=\"font-semibold text-olive-900\">知橄生活實驗室筆記：</strong></p>\n<p class=\"mb-1\">如果一家品牌宣稱其多酚極高，但 CoA 日期是 2024 年，請直接忽略。多酚會隨著儲存時間以每年約 30-40% 的速度衰減。一瓶 2024 年出具 CoA 顯示多酚 600mg/kg 的油，到 2026 年底可能只剩 200mg/kg 以下。</p>\n</blockquote>\n<h2 id=\"h-2026年的三大市場趨勢-42\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">2026 年的三大市場趨勢</h2>\n<h3 id=\"h-趨勢一qrcode溯源全面普及-43\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢一：QR Code 溯源全面普及</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">頂尖品牌（特別是希臘和義大利精品莊園）已開始在瓶身印製 QR Code，掃碼即可查看：</p>\n<ul class=\"list-none space-y-2 my-4 pl-4\">\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>採收莊園的 GPS 座標</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>採收日期與壓榨時間（採收至壓榨的間隔越短越好，目標 <4 小時）</span></li>\n<li class=\"flex gap-2 text-gray-700 leading-relaxed\"><span class=\"text-olive-500 mt-1 shrink-0\">✦</span><span>當批次第三方 CoA 完整報告</span></li>\n</ul>\n<h3 id=\"h-趨勢二早摘油earlyharvest市場-50\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢二：早摘油（Early Harvest）市場爆發</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">在 10 月初橄欖尚未完全成熟時採收的「早摘油」（也稱「青採油」或 Agura），多酚含量是完熟橄欖的 2-3 倍，但果實出油率較低（約 8-12% vs 完熟的 18-20%），導致成本更高。</p>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">知橄生活預測：2026 年早摘油在台灣消費者的認知度將從 15% 提升至 35%，帶動優質早摘油的進口量增加。</p>\n<h3 id=\"h-趨勢三多酚認證標章的崛起-53\" class=\"text-xl font-bold text-olive-800 mt-8 mb-3\">趨勢三：「多酚認證」標章的崛起</h3>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">EVOOLEUM、NYIOOC（紐約國際橄欖油大賽）等國際評鑑機構開始在官方標章旁附加多酚含量數值，讓消費者一眼識別。這是繼「有機認證」之後，橄欖油行業最重要的品質識別革命。</p>\n<h2 id=\"h-台灣消費者2026年實戰選購指南-55\" class=\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\">台灣消費者 2026 年實戰選購指南</h2>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><strong class=\"font-semibold text-olive-900\">在台灣，如何找到真正的高多酚橄欖油？</strong></p>\n<ol class=\"list-decimal pl-6 space-y-2 my-4\">\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">詢問 CoA：</strong> 向實體通路（有機商店、葡萄酒專賣店、進口食品行）直接索取，信譽好的進口商應能提供。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">辨識品種優先序：</strong> Coratina > Koroneiki 早摘 > Picual 早摘 > 其他品種。品種是多酚含量的遺傳基礎。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">看採收年份：</strong> 2025 年 10 月–2026 年 1 月採收的南半球或北半球新油，是 2026 年市場上最新鮮的選擇。</li>\n<li class=\"text-gray-700 leading-relaxed pl-1\"><strong class=\"font-semibold text-olive-900\">預算參考：</strong> 真正高多酚（>400mg/kg）的進口 EVOO，在台灣市場的合理零售價落在 <strong class=\"font-semibold text-olive-900\">NT$700-1,800/500ml</strong>，低於此價格的高多酚宣稱值得存疑。</li>\n</ol>\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\">本月，知橄生活研究團隊將對台灣市場熱銷的 10 款宣稱「高多酚」橄欖油進行盲測與第三方送驗，結果將完整公布。</p>\n<hr class=\"border-olive-200 my-10\" />\n<p class=\"text-gray-700 leading-loose mb-4 text-[1.05rem]\"><em class=\"italic\">利益揭露：知橄生活堅持獨立評測。本文提及之檢測數據由協力實驗室提供，部分連結包含聯盟營銷參數。</em></p>1e:[\"$\",\"article\",null,{\"className\":\"max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 pb-16\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-4 text-sm text-gray-400 mb-8 pb-6 border-b border-gray-100\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1\",\"children\":[\"✍️ \",[\"$\",\"span\",null,{\"className\":\"text-gray-600\",\"children\":\"知橄生活研究團隊\"}]]}],[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1\",\"children\":[\"📅 \",[\"$\",\"span\",null,{\"className\":\"text-gray-600\",\"children\":\"2026年4月27日\"}]]}],[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1\",\"children\":[\"⏱️ \",[\"$\",\"span\",null,{\"className\":\"text-gray-600\",\"children\":[10,\" 分鐘閱讀\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-gradient-to-br from-olive-50 to-gold-50 border-l-4 border-olive-500 rounded-r-xl px-6 py-5 mb-10\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-gray-600 leading-relaxed italic text-base\",\"children\":\"不談口感，我們談數據。解析 2026 年新產季歐盟與 IOC 標準下的高多酚橄欖油趨勢，教您讀懂鑑定報告中的羥基酪醇 (Hydroxytyrosol) 數值。\"}]}],null,[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 mb-8\",\"children\":[[\"$\",\"span\",\"橄欖油科學\",{\"className\":\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\",\"children\":[\"#\",\"橄欖油科學\"]}],[\"$\",\"span\",\"高多酚\",{\"className\":\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\",\"children\":[\"#\",\"高多酚\"]}],[\"$\",\"span\",\"健康數據\",{\"className\":\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\",\"children\":[\"#\",\"健康數據\"]}],[\"$\",\"span\",\"2026趨勢\",{\"className\":\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\",\"children\":[\"#\",\"2026趨勢\"]}]]}],[\"$\",\"div\",null,{\"className\":\"prose-custom\",\"dangerouslySetInnerHTML\":{\"__html\":\"$23\"}}],\"$L24\",\"$L25\",\"$L26\"]}]\n1f:[\"$\",\"section\",null,{\"className\":\"max-w-3xl mx-auto px-6 py-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"bg-olive-50 border border-olive-100 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center gap-5\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-14 h-14 rounded-full bg-olive-200 flex items-center justify-center text-2xl flex-shrink-0\",\"children\":\"🫒\"}],[\"$\",\"div\",null,{\"className\":\"flex-1\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-olive-800 mb-0.5\",\"children\":\"知橄生活研究團隊\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-500 font-sans leading-relaxed\",\"children\":\"由食品科學、分子生物學與地中海飲食研究背景的編輯團隊撰稿，引用 PREDIMED、哈佛醫學院、EFSA 等 150+ 篇學術文獻。\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex-shrink-0\",\"children\":[\"$\",\"$L27\",null,{\"title\":\"2026 橄欖油品質指數：為什麼高多酚 (High Polyphenol) 才是真正的權威標籤？\",\"url\":\"https://olive-wisdom.com/blog/2026-evoo-quality-polyphenol-index\"}]}]]}]}]\n20:[\"$\",\"section\",null,{\"className\":\"bg-olive-50 py-14 px-6\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-olive-800 mb-6\",\"children\":\"同欄目精選文章\"}],[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-3 gap-5\",\"children\":[[\"$\",\"$L2\",\"polyphenol-decay-science-2026\",{\"href\":\"/blog/polyphenol-decay-science-2026\",\"className\":\"group\",\"children\":[\"$\",\"article\",null,{\"className\":\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative h-36 overflow-hidden\",\"children\":[\"$\",\"$L1b\",null,{\"src\":\"https://bnotescoffee.com/images/ai/evoo-decay-science.jpg\",\"alt\":\"多酚衰減科學：為什麼去年的「金牌油」，今年可能只是普通烹飪油？ — 知橄生活 Olive Wisdom\",\"fill\":true,\"className\":\"object-cover group-hover:scale-105 transition-transform duration-300\",\"unoptimized\":true}]}],[\"$\",\"div\",null,{\"cla