ssName\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"橄欖油 vs 酪梨油：2026 年完整科學比較——哪種油真的更健康？\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[11,\\\" 分鐘閱讀\\\"]}]]}]]}]}],[\\\"$\\\",\\\"$L2\\\",\\\"hydroxytyrosol-brain-cognition-2026\\\",{\\\"href\\\":\\\"/blog/hydroxytyrosol-brain-cognition-2026\\\",\\\"className\\\":\\\"group\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/652adb38b9734a52bb8924925390f29d_3ef5f.png\\\",\\\"alt\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐 — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[9,\\\" 分鐘閱讀\\\"]}]]}]]}]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"22:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"💬\\\"}],\\\" 常見問題\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"details\\\",\\\"0\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"SIRT1 基因是什麼，和橄欖油有什麼關係？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"SIRT1（Sirtuin 1）是一種依賴 NAD+ 的去乙醯酶，在細胞的代謝調控、DNA 修復和抗衰老機制中扮演核心角色，被稱為「長壽基因調控器」。2013 年《Cell Metabolism》期刊的研究發現，橄欖油中的羥基酪醇（Hydroxytyrosol）和 Oleuropein 能透過提升細胞內 NAD+/NADH 比值，間接激活 SIRT1 的活性。這一機制與已知的長壽干預手段（如卡路里限制和運動）的部分生化路徑高度重疊。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"1\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖油能延長壽命嗎？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"流行病學證據支持長期高橄欖油攝取與更長壽命的正相關。2022 年《JAMA Network Open》發表的哈佛 28 年追蹤研究（涵蓋 90,000+ 人）發現，每週攝取 ≥7g/天橄欖油的人群，全因死亡率降低 19%，心血管疾病死亡率降低 19%，癌症死亡率降低 17%，神經退化性疾病死亡率降低 29%。但這些是相關性數據，不能直接聲稱「橄欖油延長壽命」，生活方式整體的地中海模式同樣是重要因素。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"2\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"白藜蘆醇和橄欖油多酚，哪個抗衰老效果更強？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"兩者作用機制不同，目前無法直接比較。白藜蘆醇（Resveratrol，主要來自紅葡萄酒）的 SIRT1 激活效果在試管實驗中較強，但人體生物利用度極低（口服吸收率 \\u003c1%），且高劑量補充劑的臨床試驗結果不一致。橄欖油多酚（羥基酪醇、Oleuropein、Oleocanthal）的人體吸收率相對較高，且有大型流行病學研究（PREDIMED）的長期實證支持。目前學界傾向認為，整體地中海飲食模式的協同效果，優於任何單一化合物的補充。\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"23:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"📚\\\"}],\\\" 參考文獻\\\"]}],[\\\"$\\\",\\\"ol\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"0\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-400 font-medium shrink-0\\\",\\\"children\\\":[\\\"[\\\",1,\\\"]\\\"]}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"PREDIMED Study, NEJM 2013\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"1\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"