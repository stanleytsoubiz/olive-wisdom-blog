d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></button></div></div></div></section><section class=\"bg-olive-50 py-14 px-6\"><div class=\"max-w-4xl mx-auto\"><h2 class=\"text-xl font-bold text-olive-800 mb-6\">同欄目精選文章</h2><div class=\"grid md:grid-cols-3 gap-5\"><a class=\"group\" href=\"/blog/olive-oil-silk-road-trade-history/\"><article class=\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\"><div class=\"relative h-36 overflow-hidden\"><img alt=\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈 — 知橄生活 Olive Wisdom\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-300\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"https://images.unsplash.com/photo-1569974507005-6dc61f97fb5e?w=1200&amp;q=80\"/></div><div class=\"p-4\"><h3 class=\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\">絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈</h3><p class=\"text-xs text-gray-400 mt-2\">8<!-- --> 分鐘閱讀</p></div></article></a><a class=\"group\" href=\"/blog/olive-oil-ancient-egypt-ritual-heritage/\"><article class=\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\"><div class=\"relative h-36 overflow-hidden\"><img alt=\"法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？ — 知橄生活 Olive Wisdom\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-300\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" src=\"https://images.unsplash.com/photo-1588703851099-c3e5f1e4a9e2?w=1200&amp;q=80\"/></div><div class=\"p-4\"><h3 class=\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\">法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？</h3><p class=\"text-xs text-gr