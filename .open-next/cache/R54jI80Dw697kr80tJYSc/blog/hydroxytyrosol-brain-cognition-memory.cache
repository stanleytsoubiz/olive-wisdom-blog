ver:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://images.unsplash.com/photo-1506484381205-f7945653044d?w=1200\\u0026auto=format\\u0026fit=crop\\u0026q=80\\\",\\\"alt\\\":\\\"橄欖油 vs 酪梨油：2026 年完整科學比較——哪種油真的更健康？ — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"橄欖油 vs 酪梨油：2026 年完整科學比較——哪種油真的更健康？\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[11,\\\" 分鐘閱讀\\\"]}]]}]]}]}],[\\\"$\\\",\\\"$L2\\\",\\\"hydroxytyrosol-brain-cognition-2026\\\",{\\\"href\\\":\\\"/blog/hydroxytyrosol-brain-cognition-2026\\\",\\\"className\\\":\\\"group\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/652adb38b9734a52bb8924925390f29d_3ef5f.png\\\",\\\"alt\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐 — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"