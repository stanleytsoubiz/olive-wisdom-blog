text-gray-400 mt-2\\\",\\\"children\\\":[7,\\\" 分鐘閱讀\\\"]}]]}]]}]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"22:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"💬\\\"}],\\\" 常見問題\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"details\\\",\\\"0\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖油外用護膚有科學根據嗎？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"有，但效果因人而異。2006 年《Skin Research and Technology》的對照研究顯示，外用高純度角鯊烯（Squalene）能顯著改善皮膚水合作用（TEWL 減少 25%）和表皮屏障功能。橄欖油中的角鯊烯含量（2,000-7,000mg/L）遠超其他植物油，且其分子結構與人體皮脂高度相似，生物相容性極佳。但對於有脂溢性皮膚炎或痘痘肌的人，橄欖油中的油酸（Oleic Acid）可能破壞皮膚屏障，需謹慎使用。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"1\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"角鯊烯和角鯊烷（Squalane）有什麼不同？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"角鯊烯（Squalene，不飽和）是橄欖油中的天然形態，活性強但較不穩定，容易氧化。角鯊烷（Squalane，飽和）是角鯊烯經氫化處理後的穩定形態，更適合作為護膚品原料，保濕效果持久且不易氧化酸化。橄欖油護膚的天然形態是角鯊烯（Squalene）；化妝品原料標示上的「Squalane」通常是合成或植物來源的氫化版本，穩定性更高。高品質護膚品通常選用角鯊烷（Squalane）以確保產品穩定性。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"2\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"哪些皮膚問題適合用橄欖油外用？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"橄欖油外用最適合：乾燥脫皮的手腳肌膚、指甲角質軟化、頭髮光澤護理（使用後需沖洗）、身體乾燥肌的全身潤膚。不建議用於：面部痘痘肌（油酸可能惡化粉刺）、脂溢性皮膚炎患者（可能加重症狀）、對橄欖過敏者。使用建議：選用高品質特級初榨橄欖油（非精製橄欖油），睡前少量塗抹於極乾燥部位，可在完整護膚程序的最後一步使用。\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"23:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"📚\\\"}],\\\" 參考文獻\\\"]}],[\\\"$\\\",\\\"ol\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\