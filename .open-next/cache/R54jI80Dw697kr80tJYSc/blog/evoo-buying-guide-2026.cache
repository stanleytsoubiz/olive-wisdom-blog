children\\\":[\\\"$\\\",\\\"$L21\\\",null,{\\\"src\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/652adb38b9734a52bb8924925390f29d_3ef5f.png\\\",\\\"alt\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐 — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[9,\\\" 分鐘閱讀\\\"]}]]}]]}]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"25:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"💬\\\"}],\\\" 常見問題\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"details\\\",\\\"0\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"What is the minimum polyphenol content I should look for in EVOO?\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"According to EFSA health claim standards, EVOO needs to contain at least 250mg/kg total polyphenols to deliver measurable cardiovascular protection (specifically 5mg/day of hydroxytyrosol and its derivatives). However, for maximum benefit, look for oils with 400-800mg/kg. Top-tier oils certified by NYIOOC Gold Award winners often exceed 500mg/kg. Always request a Certificate of Analysis (CoA) from the supplier to verify polyphenol content before purchasing.\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"1\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"How long does high-polyphenol EVOO stay fresh after opening?\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"After opening, high-quality EVOO should ideally be consumed within 60-90 days to preserve maximum polyphenol content. Research shows polyphenol levels drop by approximately 40% within 3 months of opening when stored at room temperature. To extend freshness: store in a dark, cool location (ideally 15-18°C), keep the cap tightly sealed after each use, avoid storing near heat sources like stovetops, and consider purchasing smaller bottles (250-500ml) if you don't use olive oil frequently.\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"2\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"Is Italian olive oil really better than Spanish or Greek?\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"No — this is largely a branding myth. Spain produces approximately 45% of the world's olive oil and consistently wins the most NYIOOC Gold Awards. Greek Koroneiki variety oils frequently achieve the highest polyphenol content of any cultivar globally. Italian olive oil benefits from superior brand recognition and premium pricing, but blind taste tests and chemical analysis consistently show Spanish and Greek oils matching or exceeding Italian quality benchmarks. Focus on harvest date, certifications, and polyphenol data rather than country of origin alone.\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"26:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-10 pt-8 border-t border-gray-100 flex gap-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/blog\\\",\\\"className\\\":\\\"inline-flex items-center gap-2 text-sm text-olive-600 hover:text-olive-800 font-medium hover:underline\\\",\\\"children\\\":\\\"← 返回文章列表\\\"}],[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/#subscribe\\\",\\\"className\\\":\\\"ml-auto inline-flex items-center gap-2 bg-olive-700 hover:bg-olive-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors\\\",\\\"children\\\":\\\"訂閱知橄週報 🫒\\\"}]]}]\\n\"])</scrip