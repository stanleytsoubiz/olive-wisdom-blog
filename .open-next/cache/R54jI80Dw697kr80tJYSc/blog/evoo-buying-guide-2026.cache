,null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-white font-semibold text-sm mb-4\\\",\\\"children\\\":\\\"訂閱知橄週報\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-olive-300 mb-3\\\",\\\"children\\\":\\\"每週一封，精選最新橄欖油研究與生活美學靈感。\\\"}],[\\\"$\\\",\\\"form\\\",null,{\\\"action\\\":\\\"/api/subscribe\\\",\\\"method\\\":\\\"POST\\\",\\\"className\\\":\\\"flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"input\\\",null,{\\\"type\\\":\\\"email\\\",\\\"name\\\":\\\"email\\\",\\\"required\\\":true,\\\"placeholder\\\":\\\"您的電子郵件\\\",\\\"className\\\":\\\"flex-1 text-sm bg-olive-800 border border-olive-600 text-white placeholder-olive-400 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-olive-400 min-w-0\\\"}],[\\\"$\\\",\\\"button\\\",null,{\\\"type\\\":\\\"submit\\\",\\\"className\\\":\\\"bg-gold-400 hover:bg-gold-500 text-olive-900 text-sm font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap\\\",\\\"children\\\":\\\"訂閱\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-olive-400 mt-2\\\",\\\"children\\\":\\\"訂閱即贈《橄欖油品飲師口袋手冊》PDF\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"border-t border-olive-700\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-6xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-olive-200 text-center sm:text-left\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"© 2026 知橄生活 OLIVE WISDOM. ALL RIGHTS RESERVED.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex gap-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/privacy\\\",\\\"className\\\":\\\"hover:text-white transition-colors\\\",\\\"children\\\":\\\"隱私政策\\\"}],[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/terms\\\",\\\"className\\\":\\\"hover:text-white transition-colors\\\",\\\"children\\\":\\\"使用條款\\\"}],[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/abou