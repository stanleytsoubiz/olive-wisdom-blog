n\\\":[[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/privacy\\\",\\\"className\\\":\\\"hover:text-white transition-colors\\\",\\\"children\\\":\\\"隱私政策\\\"}],[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/terms\\\",\\\"className\\\":\\\"hover:text-white transition-colors\\\",\\\"children\\\":\\\"使用條款\\\"}],[\\\"$\\\",\\\"$L2\\\",null,{\\\"href\\\":\\\"/about\\\",\\\"className\\\":\\\"hover:text-white transition-colors\\\",\\\"children\\\":\\\"關於我們\\\"}]]}]]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"9:[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[null,[\\\"$\\\",\\\"$Lf\\\",null,{\\\"parallelRouterKey\\\":\\\"children\\\",\\\"error\\\":\\\"$undefined\\\",\\\"errorStyles\\\":\\\"$undefined\\\",\\\"errorScripts\\\":\\\"$undefined\\\",\\\"template\\\":[\\\"$\\\",\\\"$L10\\\",null,{}],\\\"templateStyles\\\":\\\"$undefined\\\",\\\"templateScripts\\\":\\\"$undefined\\\",\\\"notFound\\\":\\\"$undefined\\\",\\\"forbidden\\\":\\\"$undefined\\\",\\\"unauthorized\\\":\\\"$undefined\\\"}]]}]\\na:[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[null,[\\\"$\\\",\\\"$Lf\\\",null,{\\\"parallelRouterKey\\\":\\\"children\\\",\\\"error\\\":\\\"$undefined\\\",\\\"errorStyles\\\":\\\"$undefined\\\",\\\"errorScripts\\\":\\\"$undefined\\\",\\\"template\\\":[\\\"$\\\",\\\"$L10\\\",null,{}],\\\"templateStyles\\\":\\\"$undefined\\\",\\\"templateScripts\\\":\\\"$undefined\\\",\\\"notFound\\\":\\\"$undefined\\\",\\\"forbidden\\\":\\\"$undefined\\\",\\\"unauthorized\\\":\\\"$undefined\\\"}]]}]\\nb:[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[\\\"$L11\\\",null,[\\\"$\\\",\\\"$L12\\\",null,{\\\"children\\\":[\\\"$L13\\\",[\\\"$\\\",\\\"$L14\\\",null,{\\\"promise\\\":\\\"$@15\\\"}]]}]]}]\\nc:[\\\"$\\\",\\\"$1\\\",\\\"h\\\",{\\\"children\\\":[null,[[\\\"$\\\",\\\"$L16\\\",null,{\\\"children\\\":\\\"$L17\\\"}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"next-size-adjust\\\",\\\"content\\\":\\\"\\\"}]],[\\\"$\\\",\\\"$L18\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"$19\\\",null,{\\\"fallback\\\":null,\\\"children\\\":\\\"$L1a\\\"}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"1b:I[1356,[\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"356\\\",\\\"static/chunks/356-1cbf59d25a49fb83.js\\\",\\\"953\\\",\\\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\\\"],\\\"Image\\\"]\\n1c:I[286,[\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"356\\\",\\\"static/chunks/356-1cbf59d25a49fb83.js\\\",\\\"953\\\",\\\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\\\"],\\\"default\\\"]\\n1d:T25d6,\"])</script><script>self.__next_f.push([1,\"\\u003ch2 id=\\\"h-安培拉amphorae地中海的標準化容器-0\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e安培拉（Amphorae）：地中海的標準化容器革命\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e考古學家在印度西南海岸的阿里卡梅杜（Arikamedu）挖掘出大量羅馬時代的雙耳陶罐（Amphorae）碎片。碳-14 定年顯示，這些碎片的年代約在公元前 1 世紀至公元 1 世紀之間。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e更令人震驚的發現是：這些陶罐的內壁殘留物含有\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油的特徵脂肪酸比例\\u003c/strong\\u003e——地中海橄欖油跨越了 8,000 公里的海路，抵達了印度洋岸。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e這說明了什麼？\\u003c/strong\\u003e\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e在我們慣常的「絲路」敘事中，主角是絲綢、香料和瓷器。但真實的古代貿易遠比我們想像的複雜：\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油是羅馬帝國最大宗的出口商品之一\\u003c/strong\\u003e，其貿易規模可能超過絲綢。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-雙耳罐的標準化古代的貨櫃革命-6\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e雙耳罐的標準化：古代的「貨櫃革命」\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e羅馬雙耳罐（Dressel 20 型，公元 1–3 世紀）的規格高度標準化：\\u003c/p\\u003e\\n\\u003cul class=\\\"list-none space-y-2 my-4 pl-4\\\"\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e容量\\u003c/strong\\u003e：72 公升（相當於現代 80 瓶 900ml 橄欖油）\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e重量\\u003c/strong\\u003e（空罐）：約 32 公斤\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e產地標記\\u003c/strong\\u003e：罐頸刻有生產者姓名、日期、重量\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e油封口\\u003c/strong\\u003e：用石灰和陶土密封，可保存 2–3 年\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這種標準化設計，使橄欖油成為\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e古代最易於計量、追蹤、交易的商品\\u003c/strong\\u003e——某種意義上，雙耳罐就是古代的貨櫃集裝箱。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-橄欖油在絲路的戰略角色-16\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e橄欖油在絲路的戰略角色\\u003c/h2\\u003e\\n\\u003cdiv class=\\\"overflow-x-auto my-8\\\"\\u003e\\u003ctable class=\\\"w-full border-collapse text-sm\\\"\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e路線\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e起點\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e終點\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e主要商品\\u003c/th\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e西地中海幹線\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e西班牙貝提卡\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e羅馬奧斯提亞港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油（每年 6 萬噸+）\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e東地中海海路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e亞歷山大港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e紅海阿尼克港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油 + 玻璃器\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e印度洋商路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e阿拉伯半島\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e印度馬拉巴爾海岸\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油換胡椒/棉布\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e陸上絲路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e安提阿（敘利亞）\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e帕提亞/大夏\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油換絲綢\\u003c/td\\u003e\\u003c/tr\\u003e\\u003c/table\\u003e\\u003c/div\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e公元 2 世紀，羅馬歷史學家老普林尼估計，羅馬每年光從西班牙進口的橄欖油就超過\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e10 萬噸\\u003c/strong\\u003e。這個數字，即使用現代標準衡量，也是一個驚人的貿易規模。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-蒙特泰斯塔丘一座由橄欖油罐堆成的小山-20\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e蒙特·泰斯塔丘：一座由橄欖油罐堆成的小山\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e在羅馬帝國的港口城市奧斯提亞附近，有一座高達 35 公尺、佔地約 20,000 平方公尺的小山丘。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e它的名字叫做\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e蒙特·泰斯塔丘\\u003c/strong\\u003e（Monte Testaccio），義大利語意為「陶片之山」。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這座山，\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e完全由丟棄的橄欖油雙耳罐碎片堆積而成\\u003c/strong\\u003e。考古學家估計，其中包含了超過 \\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e5,300 萬個\\u003c/strong\\u003e雙耳罐的殘骸——這意味著羅馬人在 300 年間消耗了超過 \\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e60 億公升\\u003c/strong\\u003e的橄欖油。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這不是一個奢侈品的消耗量。\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油是古代羅馬人的日常必需品\\u003c/strong\\u003e，用於烹飪、照明、沐浴、醫療、宗教儀式，甚至運動員的護膚。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-橄欖油為何沒有抵達漢朝-26\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e橄欖油為何沒有抵達漢朝\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e一個有趣的歷史謎題：儘管絲路的東段連接著漢朝中國，為什麼橄欖油似乎從未真正進入中國市場？\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e答案是\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e文化兼容性問題\\u003c/strong\\u003e。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e中國已有芝麻油、豬油等本土食用油系統，橄欖油的草本苦澀風味對習慣清淡食油的中國人而言並不友善。與此同時，橄欖樹在中國氣候下幾乎無法生長，失去了本土化生產的可能性。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e相比之下，\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e絲路輸入中國的是葡萄酒而非橄欖油\\u003c/strong\\u003e——兩者都是地中海文明的核心產物，卻有著截然不同的東方命運。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這個歷史選擇，在某種程度上，定義了此後兩千年東西方飲食文明的分野。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-延伸閱讀-33\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e延伸閱讀\\u003c/h2\\u003e\\n\\u003cul class=\\\"list-none space-y-2 my-4 pl-4\\\"\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-oil-ancient-egypt-ritual-heritage\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-tree-ancient-civilization-heritage\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e橄欖樹的不死傳說：為什麼這棵三千年的古木，見證了人類最早的文明選擇？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-oil-terroir-spain-greece-italy\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e橄欖油的風土密碼：為什麼西班牙、希臘與義大利的同種橄欖，能孕育出截然不同的靈魂？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003c/ul\\u003e\"])</script><script>self.__next_f.push([1,\"11:[\\\"$\\\",\\\"main\\\",null,{\\\"className\\\":\\\"min-h-screen bg-white\\\",\\\"children\\\":[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"Article\\\\\\\",\\\\\\\"headline\\\\\\\":\\\\\\\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈\\\\\\\",\\\\\\\"description\\\\\\\":\\\\\\\"在漢代張騫出使西域的同一個世紀，地中海商人正用雙耳陶罐將橄欖油運往印度洋港口。這條被考古學家稱為「橄欖油之路」的貿易幹線，比馬可波羅早了一千五百年。\\\\\\\",\\\\\\\"image\\\\\\\":\\\\\\\"https://images.unsplash.com/photo-1569974507005-6dc61f97fb5e?w=1200\\u0026q=80\\\\\\\",\\\\\\\"datePublished\\\\\\\":\\\\\\\"2026-04-15\\\\\\\",\\\\\\\"dateModified\\\\\\\":\\\\\\\"2026-04-15\\\\\\\",\\\\\\\"author\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Organization\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"知橄生活研究團隊\\\\\\\",\\\\\\\"url\\\\\\\":\\\\\\\"https://olive-wisdom.com\\\\\\\"},\\\\\\\"publisher\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Organization\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"知橄生活 Olive Wisdom\\\\\\\",\\\\\\\"url\\\\\\\":\\\\\\\"https://olive-wisdom.com\\\\\\\"},\\\\\\\"url\\\\\\\":\\\\\\\"https://olive-wisdom.com/blog/olive-oil-silk-road-trade-history\\\\\\\",\\\\\\\"mainEntityOfPage\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"WebPage\\\\\\\",\\\\\\\"@id\\\\\\\":\\\\\\\"https://olive-wisdom.com/blog/olive-oil-silk-road-trade-history\\\\\\\"},\\\\\\\"inLanguage\\\\\\\":\\\\\\\"zh-TW\\\\\\\",\\\\\\\"wordCount\\\\\\\":133}\\\"}}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"首頁\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://olive-wisdom.com\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"知識庫\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://olive-wisdom.com/blog\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://olive-wisdom.com/blog/olive-oil-silk-road-trade-history\\\\\\\"}]}\\\"}}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"FAQPage\\\\\\\",\\\\\\\"mainEntity\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"Question\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"橄欖油是如何沿絲路傳播的？\\\\\\\",\\\\\\\"acceptedAnswer\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Answer\\\\\\\",\\\\\\\"text\\\\\\\":\\\\\\\"橄欖油沿絲路的傳播約始於西元前 2 世紀漢武帝開通中亞貿易路線後。腓尼基商人和後來的羅馬帝國商人將橄欖油以雙耳尖底甕（Amphora）盛裝，透過陸路和海路向東方輸送。考古證據顯示，橄欖油容器曾在今伊朗、印度西北部和中亞貿易站遺址被發現。然而橄欖油從未在中國本土大規模普及，主要作為醫藥用途和外交禮品出現於史料記載中。\\\\\\\"}},{\\\\\\\"@type\\\\\\\":\\\\\\\"Question\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"古代橄欖油貿易對現代有什麼影響？\\\\\\\",\\\\\\\"acceptedAnswer\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Answer\\\\\\\",\\\\\\\"text\\\\\\\":\\\\\\\"古代橄欖油貿易確立了地中海三大產油文化圈（義大利、希臘、西班牙）的地理分工格局，這一格局延續至今。三國至今仍佔全球橄欖油產量的 70% 以上：西班牙約 45%、義大利約 15%、希臘約 13%。古代貿易路線上建立的港口城市，如西班牙塞維亞、義大利那不勒斯和希臘卡蘭馬塔，今日仍是全球橄欖油出口的重要樞紐。\\\\\\\"}},{\\\\\\\"@type\\\\\\\":\\\\\\\"Question\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"橄欖油在古代是如何儲存和運輸的？\\\\\\\",\\\\\\\"acceptedAnswer\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Answer\\\\\\\",\\\\\\\"text\\\\\\\":\\\\\\\"古代橄欖油的儲存與運輸依賴「雙耳尖底甕」（Amphora）——這種兩側有把手、底部呈尖錐狀的陶罐，容量約 25-35 升。尖底設計便於直立插入船艙沙堆固定。羅馬帝國時期，西班牙貝提卡省（今安達魯西亞）的橄欖油生產高峰期，每年向羅馬城輸送數千萬個雙耳甕。這些橄欖油甕堆積形成的人工山丘「泰斯塔喬山」（Monte Testaccio），至今仍矗立於羅馬城郊，是古代橄欖油貿易規模的直接歷史見證。\\\\\\\"}}]}\\\"}}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-[40vw] min-h-[200px] max-h-[260px] md:h-[480px] w-full\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"/images/covers/olive-oil-silk-road-trade-history.jpg\\\",\\\"alt\\\":\\\"古代絲路貿易路線地圖與橄欖油陶罐，東西方文明交流的液態黃金歷史｜知橄生活\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover\\\",\\\"priority\\\":true,\\\"unoptimized\\\":true}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute bottom-0 left-0 right-0 px-6 py-8 max-w-4xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-xs font-semibold px-3 py-1.5 rounded-full mb-4 inline-block bg-purple-100 text-purple-800\\\",\\\"children\\\":\\\"知性史詩\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-2xl md:text-4xl font-bold text-white leading-tight mt-2 max-w-3xl\\\",\\\"children\\\":\\\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈\\\"}]]}]]}],[\\\"$\\\",\\\"$L1c\\\",null,{\\\"htmlContent\\\":\\\"$1d\\\"}],\\\"$L1e\\\",\\\"$L1f\\\",\\\"$L20\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"25:I[7025,[\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"356\\\",\\\"static/chunks/356-1cbf59d25a49fb83.js\\\",\\\"953\\\",\\\"static/chunks/app/blog/%5Bslug%5D/page-8a1ac09d2c5c1bba.js\\\"],\\\"default\\\"]\\n21:T25d6,\"])</script><script>self.__next_f.push([1,\"\\u003ch2 id=\\\"h-安培拉amphorae地中海的標準化容器-0\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e安培拉（Amphorae）：地中海的標準化容器革命\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e考古學家在印度西南海岸的阿里卡梅杜（Arikamedu）挖掘出大量羅馬時代的雙耳陶罐（Amphorae）碎片。碳-14 定年顯示，這些碎片的年代約在公元前 1 世紀至公元 1 世紀之間。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e更令人震驚的發現是：這些陶罐的內壁殘留物含有\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油的特徵脂肪酸比例\\u003c/strong\\u003e——地中海橄欖油跨越了 8,000 公里的海路，抵達了印度洋岸。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e這說明了什麼？\\u003c/strong\\u003e\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e在我們慣常的「絲路」敘事中，主角是絲綢、香料和瓷器。但真實的古代貿易遠比我們想像的複雜：\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油是羅馬帝國最大宗的出口商品之一\\u003c/strong\\u003e，其貿易規模可能超過絲綢。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-雙耳罐的標準化古代的貨櫃革命-6\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e雙耳罐的標準化：古代的「貨櫃革命」\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e羅馬雙耳罐（Dressel 20 型，公元 1–3 世紀）的規格高度標準化：\\u003c/p\\u003e\\n\\u003cul class=\\\"list-none space-y-2 my-4 pl-4\\\"\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e容量\\u003c/strong\\u003e：72 公升（相當於現代 80 瓶 900ml 橄欖油）\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e重量\\u003c/strong\\u003e（空罐）：約 32 公斤\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e產地標記\\u003c/strong\\u003e：罐頸刻有生產者姓名、日期、重量\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e油封口\\u003c/strong\\u003e：用石灰和陶土密封，可保存 2–3 年\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這種標準化設計，使橄欖油成為\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e古代最易於計量、追蹤、交易的商品\\u003c/strong\\u003e——某種意義上，雙耳罐就是古代的貨櫃集裝箱。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-橄欖油在絲路的戰略角色-16\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e橄欖油在絲路的戰略角色\\u003c/h2\\u003e\\n\\u003cdiv class=\\\"overflow-x-auto my-8\\\"\\u003e\\u003ctable class=\\\"w-full border-collapse text-sm\\\"\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e路線\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e起點\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e終點\\u003c/th\\u003e\\u003cth class=\\\"border border-olive-300 px-4 py-2 font-semibold text-sm\\\" class=\\\"border border-olive-200 px-4 py-2 text-sm font-semibold bg-olive-50\\\"\\u003e主要商品\\u003c/th\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e西地中海幹線\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e西班牙貝提卡\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e羅馬奧斯提亞港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油（每年 6 萬噸+）\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e東地中海海路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e亞歷山大港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e紅海阿尼克港\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油 + 玻璃器\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e印度洋商路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e阿拉伯半島\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e印度馬拉巴爾海岸\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油換胡椒/棉布\\u003c/td\\u003e\\u003c/tr\\u003e\\u003ctr class=\\\"hover:bg-olive-50\\\"\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e陸上絲路\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e安提阿（敘利亞）\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e帕提亞/大夏\\u003c/td\\u003e\\u003ctd class=\\\"border border-olive-200 px-4 py-2 text-sm \\\"\\u003e橄欖油換絲綢\\u003c/td\\u003e\\u003c/tr\\u003e\\u003c/table\\u003e\\u003c/div\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e公元 2 世紀，羅馬歷史學家老普林尼估計，羅馬每年光從西班牙進口的橄欖油就超過\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e10 萬噸\\u003c/strong\\u003e。這個數字，即使用現代標準衡量，也是一個驚人的貿易規模。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-蒙特泰斯塔丘一座由橄欖油罐堆成的小山-20\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e蒙特·泰斯塔丘：一座由橄欖油罐堆成的小山\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e在羅馬帝國的港口城市奧斯提亞附近，有一座高達 35 公尺、佔地約 20,000 平方公尺的小山丘。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e它的名字叫做\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e蒙特·泰斯塔丘\\u003c/strong\\u003e（Monte Testaccio），義大利語意為「陶片之山」。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這座山，\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e完全由丟棄的橄欖油雙耳罐碎片堆積而成\\u003c/strong\\u003e。考古學家估計，其中包含了超過 \\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e5,300 萬個\\u003c/strong\\u003e雙耳罐的殘骸——這意味著羅馬人在 300 年間消耗了超過 \\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e60 億公升\\u003c/strong\\u003e的橄欖油。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這不是一個奢侈品的消耗量。\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e橄欖油是古代羅馬人的日常必需品\\u003c/strong\\u003e，用於烹飪、照明、沐浴、醫療、宗教儀式，甚至運動員的護膚。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-橄欖油為何沒有抵達漢朝-26\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e橄欖油為何沒有抵達漢朝\\u003c/h2\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e一個有趣的歷史謎題：儘管絲路的東段連接著漢朝中國，為什麼橄欖油似乎從未真正進入中國市場？\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e答案是\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e文化兼容性問題\\u003c/strong\\u003e。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e中國已有芝麻油、豬油等本土食用油系統，橄欖油的草本苦澀風味對習慣清淡食油的中國人而言並不友善。與此同時，橄欖樹在中國氣候下幾乎無法生長，失去了本土化生產的可能性。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e相比之下，\\u003cstrong class=\\\"font-semibold text-olive-900\\\"\\u003e絲路輸入中國的是葡萄酒而非橄欖油\\u003c/strong\\u003e——兩者都是地中海文明的核心產物，卻有著截然不同的東方命運。\\u003c/p\\u003e\\n\\u003cp class=\\\"text-gray-700 leading-loose mb-4 text-[1.05rem]\\\"\\u003e這個歷史選擇，在某種程度上，定義了此後兩千年東西方飲食文明的分野。\\u003c/p\\u003e\\n\\u003chr class=\\\"border-olive-200 my-10\\\" /\\u003e\\n\\u003ch2 id=\\\"h-延伸閱讀-33\\\" class=\\\"text-2xl font-bold text-olive-800 mt-12 mb-4 pb-2 border-b-2 border-olive-200\\\"\\u003e延伸閱讀\\u003c/h2\\u003e\\n\\u003cul class=\\\"list-none space-y-2 my-4 pl-4\\\"\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-oil-ancient-egypt-ritual-heritage\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-tree-ancient-civilization-heritage\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e橄欖樹的不死傳說：為什麼這棵三千年的古木，見證了人類最早的文明選擇？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003cli class=\\\"flex gap-2 text-gray-700 leading-relaxed\\\"\\u003e\\u003cspan class=\\\"text-olive-500 mt-1 shrink-0\\\"\\u003e✦\\u003c/span\\u003e\\u003cspan\\u003e\\u003ca href=\\\"/blog/olive-oil-terroir-spain-greece-italy\\\" class=\\\"text-olive-600 underline hover:text-olive-800\\\" target=\\\"_blank\\\" rel=\\\"noopener noreferrer\\\"\\u003e橄欖油的風土密碼：為什麼西班牙、希臘與義大利的同種橄欖，能孕育出截然不同的靈魂？\\u003c/a\\u003e\\u003c/span\\u003e\\u003c/li\\u003e\\n\\u003c/ul\\u003e\"])</script><script>self.__next_f.push([1,\"1e:[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 pb-16\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-4 text-sm text-gray-400 mb-8 pb-6 border-b border-gray-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"flex items-center gap-1\\\",\\\"children\\\":[\\\"✍️ \\\",[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-gray-600\\\",\\\"children\\\":\\\"知橄生活研究團隊\\\"}]]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"flex items-center gap-1\\\",\\\"children\\\":[\\\"📅 \\\",[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-gray-600\\\",\\\"children\\\":\\\"2026年4月15日\\\"}]]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"flex items-center gap-1\\\",\\\"children\\\":[\\\"⏱️ \\\",[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-gray-600\\\",\\\"children\\\":[8,\\\" 分鐘閱讀\\\"]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-gradient-to-br from-olive-50 to-gold-50 border-l-4 border-olive-500 rounded-r-xl px-6 py-5 mb-10\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed italic text-base\\\",\\\"children\\\":\\\"在漢代張騫出使西域的同一個世紀，地中海商人正用雙耳陶罐將橄欖油運往印度洋港口。這條被考古學家稱為「橄欖油之路」的貿易幹線，比馬可波羅早了一千五百年。\\\"}]}],null,[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 mb-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"絲路\\\",{\\\"className\\\":\\\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\\\",\\\"children\\\":[\\\"#\\\",\\\"絲路\\\"]}],[\\\"$\\\",\\\"span\\\",\\\"貿易史\\\",{\\\"className\\\":\\\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\\\",\\\"children\\\":[\\\"#\\\",\\\"貿易史\\\"]}],[\\\"$\\\",\\\"span\\\",\\\"橄欖油\\\",{\\\"className\\\":\\\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\\\",\\\"children\\\":[\\\"#\\\",\\\"橄欖油\\\"]}],[\\\"$\\\",\\\"span\\\",\\\"文明交流\\\",{\\\"className\\\":\\\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\\\",\\\"children\\\":[\\\"#\\\",\\\"文明交流\\\"]}],[\\\"$\\\",\\\"span\\\",\\\"考古\\\",{\\\"className\\\":\\\"text-xs bg-olive-100 text-olive-700 px-3 py-1 rounded-full font-medium\\\",\\\"children\\\":[\\\"#\\\",\\\"考古\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-custom\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$21\\\"}}],\\\"$L22\\\",\\\"$L23\\\",\\\"$L24\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"1f:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"max-w-3xl mx-auto px-6 py-8\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-olive-50 border border-olive-100 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center gap-5\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-14 h-14 rounded-full bg-olive-200 flex items-center justify-center text-2xl flex-shrink-0\\\",\\\"children\\\":\\\"🫒\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-bold text-olive-800 mb-0.5\\\",\\\"children\\\":\\\"知橄生活研究團隊\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-500 font-sans leading-relaxed\\\",\\\"children\\\":\\\"由食品科學、分子生物學與地中海飲食研究背景的編輯團隊撰稿，引用 PREDIMED、哈佛醫學院、EFSA 等 150+ 篇學術文獻。\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex-shrink-0\\\",\\\"children\\\":[\\\"$\\\",\\\"$L25\\\",null,{\\\"title\\\":\\\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈\\\",\\\"url\\\":\\\"https://olive-wisdom.com/blog/olive-oil-silk-road-trade-history\\\"}]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"20:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"bg-olive-50 py-14 px-6\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-4xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6\\\",\\\"children\\\":\\\"同欄目精選文章\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid md:grid-cols-3 gap-5\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2\\\",\\\"olive-oil-renaissance-art-science-history\\\",{\\\"href\\\":\\\"/blog/olive-oil-renaissance-art-science-history\\\",\\\"className\\\":\\\"group\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://images.unsplash.com/photo-1582555172866-f73bb12a2ab3?w=1200\\u0026q=80\\\",\\\"alt\\\":\\\"文藝復興的秘密溶劑：達文西、米開朗基羅如何用橄欖油定義了西方藝術的黃金時代 — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"文藝復興的秘密溶劑：達文西、米開朗基羅如何用橄欖油定義了西方藝術的黃金時代\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[8,\\\" 分鐘閱讀\\\"]}]]}]]}]}],[\\\"$\\\",\\\"$L2\\\",\\\"olive-oil-ancient-egypt-ritu