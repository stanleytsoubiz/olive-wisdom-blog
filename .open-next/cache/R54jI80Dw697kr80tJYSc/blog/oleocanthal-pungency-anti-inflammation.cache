,{\\\"src\\\":\\\"https://images.unsplash.com/photo-1506484381205-f7945653044d?w=1200\\u0026auto=format\\u0026fit=crop\\u0026q=80\\\",\\\"alt\\\":\\\"橄欖油 vs 酪梨油：2026 年完整科學比較——哪種油真的更健康？ — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"橄欖油 vs 酪梨油：2026 年完整科學比較——哪種油真的更健康？\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[11,\\\" 分鐘閱讀\\\"]}]]}]]}]}],[\\\"$\\\",\\\"$L2\\\",\\\"hydroxytyrosol-brain-cognition-2026\\\",{\\\"href\\\":\\\"/blog/hydroxytyrosol-brain-cognition-2026\\\",\\\"className\\\":\\\"group\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://picture-search.skywork.ai/skills/upload/2026-04-17/652adb38b9734a52bb8924925390f29d_3ef5f.png\\\",\\\"alt\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐 — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"2026 羥基酪醇與腦健康：橄欖油預防認知衰退的科學實踐\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[9,\\\" 分鐘閱讀\\\"]}]]}]]}]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"22:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"💬\\\"}],\\\" 常見問題\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"details\\\",\\\"0\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖油的辣喉感越強代表品質越好嗎？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"辣喉感強代表 Oleocanthal 含量高，是品質的正面指標之一，但非唯一標準。完整的品質評估應包括：果香強度（Fruitiness）、苦味（Bitterness）和辣感（Pungency）三者的平衡。IOC 感官評鑑以 0-10 分制分別評估三者，頂級 EVOO 通常三項均在 3-7 分之間。單一指標過於極端（例如僅辣感強但無果香），可能代表品種特性而非絕對的品質優越性。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"1\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"不喜歡辣喉感的人，應該選什麼品種的橄欖油？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"較溫和低辣感的品種包括：阿貝基納（Arbequina，西班牙）、萊秋諾（Leccino，義大利）和 Hojiblanca（西班牙）。這些品種的 Oleocanthal 含量天生較低，口感更柔和圓潤，適合不習慣強烈刺激感的消費者。但需注意，溫和口感通常意味著多酚含量相對較低，健康功效也較弱。晚摘（Late Harvest）的橄欖油同樣辣感較弱。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"2\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖油的辣感會隨時間消失嗎？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"是的。Oleocanthal 是橄欖油中最不穩定的多酚化合物之一，對光線、溫度和氧化極為敏感。研究顯示，橄欖油開封後在室溫（25°C）下保存 6 個月，Oleocanthal 含量可下降 50% 以上。未開封的橄欖油在正確儲存（遮光、陰涼、密封）條件下，採收後 12-18 個月仍能保有相當比例的活性多酚。這也是為什麼採收年份對購買決策如此重要。\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"23:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"📚\\\"}],\\\" 參考文獻\\\"]}],[\\\"$\\\",\\\"ol\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"0\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"cla