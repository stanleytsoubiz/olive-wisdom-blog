Name\":\"relative h-36 overflow-hidden\",\"children\":[\"$\",\"$L1b\",null,{\"src\":\"https://images.unsplash.com/photo-1569974507005-6dc61f97fb5e?w=1200&q=80\",\"alt\":\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈 — 知橄生活 Olive Wisdom\",\"fill\":true,\"className\":\"object-cover group-hover:scale-105 transition-transform duration-300\",\"unoptimized\":true}]}],[\"$\",\"div\",null,{\"className\":\"p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\",\"children\":\"絲路上的液態黃金：橄欖油如何在西元前連結東西方文明的貿易命脈\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mt-2\",\"children\":[8,\" 分鐘閱讀\"]}]]}]]}]}],[\"$\",\"$L2\",\"olive-tree-ancient-civilization-heritage\",{\"href\":\"/blog/olive-tree-ancient-civilization-heritage\",\"className\":\"group\",\"children\":[\"$\",\"article\",null,{\"className\":\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"relative h-36 overflow-hidden\",\"children\":[\"$\",\"$L1b\",null,{\"src\":\"https://picture-search.skywork.ai/skills/upload/2026-04-17/7c6e503d6ec349d6aa0aa91b5e992216_9be28.png\",\"alt\":\"橄欖樹的不死傳說：為什麼這棵三千年的古木，見證了人類最早的文明選擇？ — 知橄生活 Olive Wisdom\",\"fill\":true,\"className\":\"object-cover group-hover:scale-105 transition-transform duration-300\",\"unoptimized\":true}]}],[\"$\",\"div\",null,{\"className\":\"p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\",\"children\":\"橄欖樹的不死傳說：為什麼這棵三千年的古木，見證了人類最早的文明選擇？\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mt-2\",\"children\":[9,\" 分鐘閱讀\"]}]]}]]}]}]]}]]}]}]\n22:[\"$\",\"div\",null,{\"className\":\"mt-12 pt-8 border-t border-olive-100\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"children\":\"💬\"}],\" 常見問題\"]}],[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"details\",\"0\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"古埃及人如何使用橄欖油？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"古埃及橄欖油的用途遠超飲食範疇。根據考古文獻和莎草紙記載，橄欖油在埃及主要用於：(1) 宗教儀式中膏抹神像和法老（「聖膏油」）；(2) 木乃伊防腐處理，覆蓋遺體以延緩腐化；(3) 照明，作為神殿油燈的燃料；(4) 香料調配的基底油；(5) 菁英階層的皮膚與頭髮護理。橄欖油在古埃及的稀缺性使其成為財富與神聖的象徵，普通平民幾乎無緣取得。\"}]]}],[\"$\",\"details\",\"1\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"橄欖樹在古埃及存在嗎？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"有限存在。橄欖樹並非埃及原生植物，考古證據顯示約在西元前 1600 年（新王國時期）前後，橄欖樹種植才開始出現於埃及三角洲地區，主要來自地中海東岸（今以色列/黎巴嫩一帶）的引進。圖坦卡蒙（約西元前 1323 年）墓葬中發現了橄欖樹枝，是橄欖在古埃及具有重要文化意義的直接考古證據。大部分橄欖油仍依賴從迦南和希臘地區進口。\"}]]}],[\"$\",\"details\",\"2\",{\"className\":\"group border border-olive-200 rounded-xl overflow-hidden\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\",\"children\":\"地中海橄欖油文化從哪個文明起源？\"}],[\"$\",\"span\",null,{\"className\":\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\",\"children\":\"▾\"}]]}],[\"$\",\"div\",null,{\"className\":\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\",\"children\":\"考古和遺傳學研究指出，橄欖樹的系統性栽培最早可追溯至約西元前 6000-7000 年的近東地區（現今以色列、巴勒斯坦和敘利亞一帶）。約西元前 3500 年，橄欖油生產技術傳播至克里特島，米諾斯文明建立了第一批大規模橄欖油生產和貿易體系。之後透過腓尼基人和希臘人的海上貿易網絡，橄欖油文化逐漸擴展至整個地中海世界。\"}]]}]]}]]}]\n23:[\"$\",\"div\",null,{\"className\":\"mt-12 pt-8 border-t border-olive-100\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"children\":\"📚\"}],\" 參考文獻\"]}],[\"$\",\"ol\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",1,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"J. Matalas, Olive Oil in Ancient Egypt, 2018\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"text-sm text-gray-500 flex gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-olive-400 font-medium shrink-0\",\"children\":[\"[\",2,\"]\"]}],[\"$\",\"span\",null,{\"children\":\"Ebers Papyrus (c.1550 BC)\"}]]}]]}]]}]\n24:[\"$\",\"div\",null,{\"className\":\"mt-10 pt-8 border-t border-gray-100 flex gap-4\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/blog\",\"className\":\"inline-flex items-center gap-2 text-sm text-olive-600 hover:text-olive-800 font-medium hover:underline\",\"children\":\"← 返回文章列表\"}],[\"$\",\"$L2\",null,{\"href\":\"/#subscribe\",\"className\":\"ml-auto inline-flex items-center gap-2 bg-olive-700 hover:bg-olive-800 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors\",\"children\":\"訂閱知橄週報 🫒\"}]]}]\n17:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n13:null\n15:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？｜知橄生活｜知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"從圖坦卡門陵墓中出土的橄欖油容器，到《埃伯斯紙草卷》中記載的 700 種醫療配方——橄欖油在 4,000 年前的埃及，不只是食物，更是連結生死兩界的神聖媒介。\"}],[\"$\",\"link\",\"2\",{\"rel\":\"author\",\"href\":\"https://olive-wisdom.com\"}],[\"$\",\"meta\",\"3\",{\"name\":\"author\",\"content\":\"知橄生活研究團隊\"}],[\"$\",\"meta\",\"4\",{\"name\":\"keywords\",\"content\":\"橄欖油,特級初榨橄欖油,EVOO,地中海飲食,抗衰老,多酚,羥基酪醇,SIRT1,健康飲食\"}],[\"$\",\"meta\",\"5\",{\"name\":\"creator\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"6\",{\"name\":\"publisher\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"7\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"link\",\"8\",{\"rel\":\"canonical\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-ancient-egypt-ritual-heritage/\"}],[\"$\",\"link\",\"9\",{\"rel\":\"alternate\",\"hrefLang\":\"zh-TW\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-ancient-egypt-ritual-heritage/\"}],[\"$\",\"link\",\"10\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://olive-wisdom.com/blog/olive-oil-ancient-egypt-ritual-heritage/\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:title\",\"content\":\"法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:description\",\"content\":\"從圖坦卡門陵墓中出土的橄欖油容器，到《埃伯斯紙草卷》中記載的 700 種醫療配方——橄欖油在 4,000 年前的埃及，不只是食物，更是連結生死兩界的神聖媒介。\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:url\",\"content\":\"https://olive-wisdom.com/blog/olive-oil-ancient-egypt-ritual-heritage/\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:site_name\",\"content\":\"知橄生活 Olive Wisdom\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:locale\",\"content\":\"zh_TW\"}],[\"$\",\"meta\",\"16\",{\"property\":\"og: