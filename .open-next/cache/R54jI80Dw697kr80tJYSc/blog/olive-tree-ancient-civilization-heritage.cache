\":\\\"group\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"bg-white rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative h-36 overflow-hidden\\\",\\\"children\\\":[\\\"$\\\",\\\"$L1b\\\",null,{\\\"src\\\":\\\"https://images.unsplash.com/photo-1588703851099-c3e5f1e4a9e2?w=1200\\u0026q=80\\\",\\\"alt\\\":\\\"法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？ — 知橄生活 Olive Wisdom\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover group-hover:scale-105 transition-transform duration-300\\\",\\\"unoptimized\\\":true}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-olive-800 line-clamp-2 group-hover:text-olive-600 transition-colors\\\",\\\"children\\\":\\\"法老的聖油：為什麼橄欖油在古埃及是比黃金更珍貴的文明符碼？\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-gray-400 mt-2\\\",\\\"children\\\":[9,\\\" 分鐘閱讀\\\"]}]]}]]}]}]]}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"22:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-olive-800 mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"💬\\\"}],\\\" 常見問題\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"details\\\",\\\"0\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"世界上最老的橄欖樹有多老？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"目前記錄在案最古老的橄欖樹位於克里特島（希臘），科學碳定年結果估計樹齡超過 3,000-4,000 年（部分研究認為可達 5,000 年）。這棵「Vouves 橄欖樹」至今仍能結果，其橄欖籽已被用於新橄欖樹的繁殖。在以色列、巴勒斯坦和西班牙也有多棵被確認超過 2,000 年的古橄欖樹仍持續生長結果，見證了橄欖樹超凡的生命韌性。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"1\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖樹為什麼對地中海文明如此重要？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"橄欖樹在地中海文明中扮演了食物、能源、藥物、宗教和外交的多重角色。在農業層面，它是地中海乾燥氣候下最可靠的高價值作物，耐旱能力極強。在文化層面，橄欖枝是希臘奧林匹克冠軍的頒獎桂冠、《聖經》中諾亞方舟洪水退去的和平符號、雅典城邦的守護神徽記，也是古羅馬帝國的官方勝利象徵。其無處不在的文化意涵，使橄欖樹成為地中海文明認同的核心符碼。\\\"}]]}],[\\\"$\\\",\\\"details\\\",\\\"2\\\",{\\\"className\\\":\\\"group border border-olive-200 rounded-xl overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"summary\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-5 py-4 cursor-pointer bg-olive-50 hover:bg-olive-100 transition-colors list-none\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"font-semibold text-olive-800 text-sm leading-relaxed pr-4\\\",\\\"children\\\":\\\"橄欖油在古希臘奧林匹克有什麼作用？\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-500 shrink-0 text-lg group-open:rotate-180 transition-transform duration-200\\\",\\\"children\\\":\\\"▾\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"px-5 py-4 text-gray-600 text-sm leading-relaxed bg-white\\\",\\\"children\\\":\\\"橄欖油在古希臘奧林匹克中有三重功能：(1) 運動員賽前用橄欖油全身塗抹，增加肌膚彈性並防止過度摩擦受傷；(2) 聖火和神廟油燈使用最純淨的橄欖油作為燃料；(3) 奧林匹亞競技勝利者獲贈以野生橄欖枝編成的桂冠（Kotinos），同時獲授一大甕（約 40kg）來自雅典聖橄欖樹的橄欖油——這是當時極具價值的物質獎勵。雅典泛雅典娜節競技的優勝者甚至可獲贈數十至數百甕橄欖油，足以維持數年生計。\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"23:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-12 pt-8 border-t border-olive-100\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-olive-800 mb-4 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"📚\\\"}],\\\" 參考文獻\\\"]}],[\\\"$\\\",\\\"ol\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"0\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-400 font-medium shrink-0\\\",\\\"children\\\":[\\\"[\\\",1,\\\"]\\\"]}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Zohary, D. \\u0026 Hopf, M. (2000). Domestication of Plants in the Old World. Oxford University Press.\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"1\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-400 font-medium shrink-0\\\",\\\"children\\\":[\\\"[\\\",2,\\\"]\\\"]}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":\\\"Besnard, G. et al. (2013). The complex history of the olive tree. Proceedings of the Royal Society B.\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"2\\\",{\\\"className\\\":\\\"text-sm text-gray-500 flex gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-olive-400 font-medium shrink-0\\\",\\\"children\\\":[\\\"[\\\",3,\\\"]\\\"]}],[\\\"$\\\",\\\"span\\\",null,{\\