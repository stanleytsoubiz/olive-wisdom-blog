,\\\"content\\\":\\\"知橄生活 Olive Wisdom\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"6\\\",{\\\"name\\\":\\\"publisher\\\",\\\"content\\\":\\\"知橄生活 Olive Wisdom\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"7\\\",{\\\"name\\\":\\\"robots\\\",\\\"content\\\":\\\"index, follow\\\"}],[\\\"$\\\",\\\"link\\\",\\\"8\\\",{\\\"rel\\\":\\\"canonical\\\",\\\"href\\\":\\\"https://olive-wisdom.com/blog/evoo-sensory-evaluation-ioc-standards/\\\"}],[\\\"$\\\",\\\"link\\\",\\\"9\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"zh-TW\\\",\\\"href\\\":\\\"https://olive-wisdom.com/blog/evoo-sensory-evaluation-ioc-standards/\\\"}],[\\\"$\\\",\\\"link\\\",\\\"10\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"x-default\\\",\\\"href\\\":\\\"https://olive-wisdom.com/blog/evoo-sensory-evaluation-ioc-standards/\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"11\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\\\"IOC 感官評鑑全解析：為什麼一瓶橄欖油的靈魂，藏在鼻尖的三秒鐘？\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"12\\\",{\\\"property\\\":\\\"og:description\\\",\\\"content\\\":\\\"國際橄欖油委員會（IOC）的官方感官評鑑方法，要求品油師在 28°C 的藍色杯中，靜靜感受那三秒的香氣爆發。學會這套語言，您將不再被標籤欺騙。\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"13\\\",{\\\"property\\\":\\\"og:url\\\",\\\"content\\\":\\\"https://olive-wisdom.com/blog/evoo-sensory-evaluation-ioc-standards/\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"14\\\",{\\\"property\\\":\\\"og:site_name\\\",\\\"content\\\":\\\"知橄生活 Olive Wisdom\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"15\\\",{\\\"property\\\":\\\"og:locale\\\",\\\"content\\\":\\\"zh_TW\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"16\\\",{\\\"property\\\":\\\"og:image\\\",\\\"content\\\":\\\"https://bnotescoffee.com/images/ai/evoo-tasting-science.jpg\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"17\\\",{\\\"property\\\":\\\"og:image:width\\\",\\\"content\\\":\\\"1200\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"18\\\",{\\\"property\\\":\\\"og:image:height\\\",\\\"content\\\":\\\"630\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"19\\\",{\\\"property\\\":\\\"og:image:alt\\\",\\\"content\\\":\\\"IOC 感官評鑑全解析：為什麼一瓶橄欖油的靈魂，藏在鼻尖的三秒鐘？\\\"}],[\\\"$\\\",\