\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":[\\\"Organization\\\",\\\"NewsMediaOrganization\\\"],\\\"name\\\":\\\"知橄生活 Olive Wisdom\\\",\\\"alternateName\\\":\\\"Olive Wisdom Blog\\\",\\\"url\\\":\\\"https://olive-wisdom.com\\\",\\\"logo\\\":\\\"https://olive-wisdom.com/favicon.ico\\\",\\\"description\\\":\\\"由食品科學、分子生物學與地中海飲食研究背景的編輯團隊撰稿，引用 PREDIMED、哈佛醫學院、EFSA 等 150+ 篇學術文獻的橄欖油知識平台。\\\",\\\"knowsAbout\\\":[\\\"橄欖油\\\",\\\"地中海飲食\\\",\\\"多酚\\\",\\\"特級初榨橄欖油\\\",\\\"抗老化科學\\\",\\\"EVOO\\\"],\\\"sameAs\\\":[\\\"https://olive-wisdom.com\\\"],\\\"foundingDate\\\":\\\"2026\\\",\\\"inLanguage\\\":\\\"zh-TW\\\",\\\"publishingPrinciples\\\":\\\"https://olive-wisdom.com/about\\\",\\\"correctionsPolicy\\\":\\\"https://olive-wisdom.com/about\\\"}\"}}],[\"$\",\"section\",null,{\"className\":\"relative h-72 md:h-96 overflow-hidden\",\"children\":[[\"$\",\"$L10\",null,{\"src\":\"https://images.unsplash.com/photo-1474979266404-7eaacbcd87c5?w=1600&auto=format&fit=crop&q=80\",\"alt\":\"知橄生活 — 關於我們\",\"fill\":true,\"className\":\"object-cover\",\"priority\":true,\"unoptimized\":true}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 bg-gradient-to-b from-olive-900/60 to-olive-800/80\"}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 flex items-center justify-center text-center text-white px-6\",\"children\":[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-gold-400 text-xs tracking-[0.3em] uppercase mb-3\",\"children\":\"About Us\"}],[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-5xl font-bold mb-3\",\"children\":\"關於知橄生活\"}],[\"$\",\"p\",null,{\"className\":\"text-olive-200 text-lg\",\"children\":\"真正的選擇，始於真正的理解。\"}]]}]}]]}],[\"$\",\"section\",null,{\"className\":\"max-w-4xl mx-auto px-6 py-20\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-2 gap-12 items-center\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-olive-600 text-sm font-medium tracking-widest uppercase mb-3\",\"children\":\"Our Mission\"}],[\"$\",\"h2\",null,{\"className\":\"text-3xl font-bold text-olive-800 mb-6\",\"children\":\"為什麼是知橄生活？\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-gray-600 leading-relaxed\",\"children\":[[\"$\",\"p\",null,{\"children\":\"橄欖油的世界，充斥著行銷話術與知識斷層。我們的讀者——35 歲以上、重視健康品質、願意深入理解的知性人士——值得更好的資訊環境。\"}],[\"$\",\"p\",null,{\"children\":\"知橄生活不是另一個「10 個橄欖油好處」的清單部落格。我們是一個知識深潛基地，帶您了解「羥基酪醇如何透過 Nrf2 通路在 DNA 層級建立抗老防護」這種層次的知識。\"}],[\"$\",\"p\",null,{\"children\":\"每一篇文章，都錨定在可追溯的學術文獻上；每一個健康聲稱，都需要 PREDIMED、哈佛醫學院、EFSA 的研究數據支撐。\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-olive-50 rounded-2xl p-8 border border-olive-100\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-olive-800 mb-6\",\"children\":\"品牌三位一體\"}],[\"$\",\"div\",null,{\"className\":\"space-y-5\",\"children\":[[\"$\",\"div\",\"科學嚴謹\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-2xl shrink-0\",\"children\":\"🔬\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-olive-700 mb-1\",\"children\":\"科學嚴謹\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-500\",\"children\":\"每個主張必須可溯源至學術文獻（PREDIMED、哈佛、EFSA、IOC）\"}]]}]]}],[\"$\",\"div\",\"知性優雅\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-2xl shrink-0\",\"children\":\"✍️\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-olive-700 mb-1\",\"children\":\"知性優雅\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-500\",\"children\":\"語言如散文，不像說明書；如導師，不像廣告\"}]]}]]}],[\"$\",\"div\",\"生活美學\",{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-2xl shrink-0\",\"children\":\"🏡\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-olive-700 mb-1\",\"children\":\"生活美學\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-500\",\"children\":\"將知識轉化為可實踐的生活儀式感\"}]]}]]}]]}]]}]]}]}],[\"$\",\"se